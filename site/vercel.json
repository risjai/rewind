{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "astro",
  "git": {
    "deploymentEnabled": {
      "master": true,
      "main": true
    }
  },
  "ignoreCommand": "git fetch --deepen=2 && git diff HEAD~1 HEAD --quiet -- site/"
}
