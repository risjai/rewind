---

---

<section id="demo" class="py-20 md:py-28">
  <div class="mx-auto max-w-5xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">
        See it in action
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-neutral-400">
        A full debug cycle in under 60 seconds — record, inspect, fork, diff.
      </p>
    </div>

    <div class="mt-12 grid gap-8 md:grid-cols-[1fr_280px] items-start">
      <!-- Video in terminal chrome -->
      <div class="overflow-hidden rounded-2xl border border-neutral-800">
        <div
          class="flex items-center gap-2 border-b border-neutral-800 bg-neutral-900 px-4 py-3"
        >
          <div class="h-3 w-3 rounded-full bg-red-500/70"></div>
          <div class="h-3 w-3 rounded-full bg-yellow-500/70"></div>
          <div class="h-3 w-3 rounded-full bg-green-500/70"></div>
          <span class="ml-3 text-xs text-neutral-500 font-mono">rewind</span>
        </div>
        <div class="bg-neutral-950 p-2">
          <video
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            class="w-full"
            aria-label="Rewind demo showing trace inspection, timeline diff, and cached replay"
          >
            <source src="/demo.mp4" type="video/mp4" />
            <img src="/demo.gif" alt="Rewind demo" class="w-full" loading="lazy" />
          </video>
        </div>
      </div>

      <!-- What you're seeing -->
      <div class="space-y-4">
        <div class="rounded-xl border border-neutral-800 bg-neutral-900/30 p-4">
          <div class="flex items-center gap-2.5 mb-2">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-brand-primary/10 text-brand-primary" aria-hidden="true">
              <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            </span>
            <span class="text-sm font-semibold">No API keys</span>
          </div>
          <p class="text-xs leading-relaxed text-neutral-400">
            The demo runs with built-in sample data. No OpenAI key, no cloud account, nothing to configure.
          </p>
        </div>

        <div class="rounded-xl border border-neutral-800 bg-neutral-900/30 p-4">
          <div class="flex items-center gap-2.5 mb-2">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-brand-primary/10 text-brand-primary" aria-hidden="true">
              <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </span>
            <span class="text-sm font-semibold">Cached steps = free</span>
          </div>
          <p class="text-xs leading-relaxed text-neutral-400">
            Watch the replay counter — steps before the fork point return instantly from cache. Zero tokens, zero cost.
          </p>
        </div>

        <div class="rounded-xl border border-neutral-800 bg-neutral-900/30 p-4">
          <div class="flex items-center gap-2.5 mb-2">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-brand-primary/10 text-brand-primary" aria-hidden="true">
              <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            </span>
            <span class="text-sm font-semibold">Everything local</span>
          </div>
          <p class="text-xs leading-relaxed text-neutral-400">
            All data in a SQLite database on your machine. The entire tool is one binary — nothing phones home.
          </p>
        </div>
      </div>
    </div>

    <div class="mt-8 text-center">
      <p class="text-sm text-neutral-500">
        Try it yourself — no API keys needed:
      </p>
      <code
        class="mt-2 inline-block rounded-lg bg-neutral-900 border border-neutral-800 px-4 py-2 font-mono text-sm text-neutral-300"
      >
        rewind demo && rewind inspect latest
      </code>
    </div>
  </div>
</section>
