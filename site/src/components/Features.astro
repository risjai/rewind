---
const heroFeature = {
  icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
  title: "Fork & Replay",
  description:
    "Branch at any step. Fix your code, replay from failure. Steps before the fork are cached — 0 tokens, 0ms. No other tool does this.",
  image: "/screenshot-session-trace.png",
  imageAlt: "Rewind session trace showing step-by-step timeline with fork points",
};

const mediumFeatures = [
  {
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: "Prove the Fix",
    description:
      "Score original vs. forked timelines with LLM-as-judge. Correctness, coherence, safety — scored automatically. Ship with evidence, not hope.",
    image: "/screenshot-error-detail.png",
    imageAlt: "Rewind error detail view showing evaluation scores across timelines",
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>`,
    title: "Session Sharing",
    description:
      "Generate a self-contained HTML file. Open in any browser, share via Slack or email. No install, no login, works offline.",
    image: "/screenshot-share-html.png",
    imageAlt: "Rewind self-contained HTML share viewer open in a browser",
  },
];

const compactFeatures = [
  {
    icon: `<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: "Instant Replay",
    description:
      "Identical requests served from cache at 0 tokens, 0ms. Run the same agent 10 times — only the first hits the LLM.",
  },
  {
    icon: `<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>`,
    title: "Import & Debug",
    description:
      "Import traces from Langfuse, Datadog, or any OTel backend. Fork at the failure, replay locally, export the fix back.",
  },
  {
    icon: `<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    title: "Regression Testing",
    description:
      "Turn any session into a baseline. Check step types, models, tool calls, and token drift. 3-line GitHub Action.",
  },
];

const extraFeatures = [
  {
    icon: `<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>`,
    title: "Snapshots",
    description:
      "Checkpoint your workspace before an agent runs. Restore in one command if it breaks something. No git required.",
  },
  {
    icon: `<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>`,
    title: "Web Dashboard",
    description:
      "Browser-based session explorer with live recording via WebSocket. Step timeline, context viewer, eval dashboard — all embedded in the binary.",
  },
  {
    icon: `<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/></svg>`,
    title: "SQL Explorer",
    description:
      "Run ad-hoc SQL against the Rewind database. Token usage by model, cost estimation, session analytics — read-only, safe to explore.",
  },
];
---

<section id="features" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">
        Chrome DevTools for AI agents
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-neutral-400">
        Record, inspect, fork, replay, diff, evaluate — all on the same
        timeline. The only tool where debugging, tracing, and evals share the
        same data model.
      </p>
    </div>

    <!-- Hero feature: Fork & Replay (full width with screenshot) -->
    <div class="mt-16 overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-900/30">
      <div class="grid md:grid-cols-2">
        <div class="flex flex-col justify-center p-8 md:p-10">
          <div class="mb-4 inline-flex w-fit rounded-xl bg-brand-primary/10 p-2.5 text-brand-primary" aria-hidden="true">
            <Fragment set:html={heroFeature.icon} />
          </div>
          <h3 class="text-2xl font-bold">{heroFeature.title}</h3>
          <p class="mt-3 text-base leading-relaxed text-neutral-400">
            {heroFeature.description}
          </p>
          <span class="mt-4 inline-flex items-center gap-1.5 text-xs font-medium text-brand-primary">
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            Only Rewind does this
          </span>
        </div>
        <div class="border-t border-neutral-800 md:border-l md:border-t-0">
          <img
            src={heroFeature.image}
            alt={heroFeature.imageAlt}
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>

    <!-- Medium features: 2-column with screenshots -->
    <div class="mt-6 grid gap-6 md:grid-cols-2">
      {
        mediumFeatures.map((f) => (
          <div class="overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-900/30 transition hover:border-neutral-700">
            <div class="p-6">
              <div class="mb-3 inline-flex rounded-xl bg-brand-primary/10 p-2.5 text-brand-primary" aria-hidden="true">
                <Fragment set:html={f.icon} />
              </div>
              <h3 class="text-lg font-semibold">{f.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-neutral-400">
                {f.description}
              </p>
            </div>
            <div class="border-t border-neutral-800">
              <img
                src={f.image}
                alt={f.imageAlt}
                class="w-full"
                loading="lazy"
              />
            </div>
          </div>
        ))
      }
    </div>

    <!-- Compact features: 3-column row -->
    <div class="mt-6 grid gap-6 sm:grid-cols-3">
      {
        compactFeatures.map((f) => (
          <div class="rounded-2xl border border-neutral-800 bg-neutral-900/30 p-6 transition hover:border-neutral-700">
            <div class="mb-3 inline-flex rounded-lg bg-brand-primary/10 p-2 text-brand-primary" aria-hidden="true">
              <Fragment set:html={f.icon} />
            </div>
            <h3 class="text-base font-semibold">{f.title}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-neutral-400">
              {f.description}
            </p>
          </div>
        ))
      }
    </div>

    <!-- Extra features: second 3-column row -->
    <div class="mt-6 grid gap-6 sm:grid-cols-3">
      {
        extraFeatures.map((f) => (
          <div class="rounded-2xl border border-neutral-800 bg-neutral-900/30 p-6 transition hover:border-neutral-700">
            <div class="mb-3 inline-flex rounded-lg bg-brand-primary/10 p-2 text-brand-primary" aria-hidden="true">
              <Fragment set:html={f.icon} />
            </div>
            <h3 class="text-base font-semibold">{f.title}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-neutral-400">
              {f.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
