---

---

<section class="border-t border-neutral-800/50 py-20 md:py-28">
  <div class="mx-auto max-w-3xl px-6 text-center">
    <h2 class="text-3xl font-bold tracking-tight md:text-4xl">
      Start debugging in
      <span
        class="bg-gradient-to-r from-brand-cyan to-brand-violet bg-clip-text text-transparent"
        >30 seconds</span
      >
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-neutral-400">
      One install. One line of code. Zero config.
    </p>

    <!-- Terminal block -->
    <div
      class="mx-auto mt-10 max-w-xl overflow-hidden rounded-2xl border border-neutral-800 text-left"
    >
      <div
        class="flex items-center gap-2 border-b border-neutral-800 bg-neutral-900 px-4 py-3"
      >
        <div class="h-3 w-3 rounded-full bg-red-500/70"></div>
        <div class="h-3 w-3 rounded-full bg-yellow-500/70"></div>
        <div class="h-3 w-3 rounded-full bg-green-500/70"></div>
        <span class="ml-3 text-xs text-neutral-500 font-mono">terminal</span>
      </div>
      <div class="bg-neutral-950 p-6 font-mono text-sm leading-relaxed" role="code">
        <div>
          <span class="text-neutral-500 select-none">$ </span><span
            class="text-brand-cyan">pip install</span
          ><span class="text-neutral-200"> rewind-agent</span>
        </div>
        <div class="mt-3 text-neutral-600"># Add one line to your agent:</div>
        <div class="mt-1">
          <span class="text-brand-violet">import</span><span
            class="text-neutral-200"
          >
            rewind_agent</span
          >
        </div>
        <div>
          <span class="text-neutral-200">rewind_agent</span><span
            class="text-neutral-500">.</span
          ><span class="text-brand-cyan">init</span><span
            class="text-neutral-500">()</span
          >
        </div>
        <div class="mt-3 text-neutral-600"># Run your agent, then:</div>
        <div class="mt-1">
          <span class="text-neutral-500 select-none">$ </span><span
            class="text-neutral-200">rewind show latest</span
          >
        </div>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <a
        href="https://github.com/agentoptics/rewind"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-xl bg-brand-cyan px-6 py-3 text-sm font-semibold text-neutral-950 transition hover:bg-brand-cyan/90"
      >
        Get started
        <svg
          class="h-4 w-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
        </svg>
      </a>
      <a
        href="https://github.com/agentoptics/rewind/blob/master/docs/getting-started.md"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium text-neutral-400 transition hover:text-neutral-200"
      >
        Read the docs &rarr;
      </a>
    </div>
  </div>
</section>
