---

---

<section id="how-it-works" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center">
      <span class="inline-block rounded-full bg-brand-primary/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-brand-primary">
        3 simple steps
      </span>
      <h2 class="mt-4 text-3xl font-bold tracking-tight md:text-4xl">
        From first install to fixed agent in minutes
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-neutral-400">
        One line of code. Zero config. No API keys needed.
      </p>
    </div>

    <div class="mt-16 grid gap-8 lg:grid-cols-3">
      <!-- Step 1: Record -->
      <div class="group relative">
        <div class="overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-900/30 transition group-hover:border-neutral-700">
          <!-- Mockup terminal -->
          <div class="border-b border-neutral-800 bg-neutral-900 px-4 py-2.5 flex items-center gap-2">
            <div class="h-3 w-3 rounded-full bg-red-500/70"></div>
            <div class="h-3 w-3 rounded-full bg-yellow-500/70"></div>
            <div class="h-3 w-3 rounded-full bg-green-500/70"></div>
            <span class="ml-2 text-[10px] text-neutral-600 font-mono">agent.py</span>
          </div>
          <div class="bg-neutral-950 p-5 font-mono text-xs leading-relaxed">
            <div><span class="text-brand-accent">import</span> <span class="text-neutral-200">rewind_agent</span></div>
            <div><span class="text-brand-accent">import</span> <span class="text-neutral-200">openai</span></div>
            <div class="mt-3"><span class="text-neutral-200">rewind_agent</span><span class="text-neutral-500">.</span><span class="text-brand-primary">init</span><span class="text-neutral-500">()</span> <span class="text-neutral-600"># that's it</span></div>
            <div class="mt-3"><span class="text-neutral-200">client</span> <span class="text-neutral-500">=</span> <span class="text-neutral-200">openai</span><span class="text-neutral-500">.</span><span class="text-neutral-200">OpenAI</span><span class="text-neutral-500">()</span></div>
            <div><span class="text-neutral-200">client</span><span class="text-neutral-500">.</span><span class="text-neutral-200">chat</span><span class="text-neutral-500">.</span><span class="text-neutral-200">completions</span><span class="text-neutral-500">.</span><span class="text-neutral-200">create</span><span class="text-neutral-500">(</span><span class="text-neutral-500">...</span><span class="text-neutral-500">)</span></div>
          </div>

          <div class="p-6">
            <div class="flex items-center gap-3 mb-3">
              <span class="flex h-8 w-8 items-center justify-center rounded-full bg-brand-primary/10 text-sm font-bold text-brand-primary">1</span>
              <h3 class="text-lg font-bold">Record</h3>
            </div>
            <p class="text-sm leading-relaxed text-neutral-400">
              Add one line to your Python agent. Every LLM call, tool invocation, and context window is captured automatically. Or use the HTTP proxy for any language.
            </p>
          </div>
        </div>
        <!-- Connector arrow (desktop) -->
        <div class="hidden lg:block absolute -right-4 top-1/2 -translate-y-1/2 z-10 text-neutral-700" aria-hidden="true">
          <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </div>
      </div>

      <!-- Step 2: Inspect -->
      <div class="group relative">
        <div class="overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-900/30 transition group-hover:border-neutral-700">
          <!-- Mockup trace view -->
          <div class="border-b border-neutral-800 bg-neutral-900 px-4 py-2.5 flex items-center gap-2">
            <div class="h-3 w-3 rounded-full bg-red-500/70"></div>
            <div class="h-3 w-3 rounded-full bg-yellow-500/70"></div>
            <div class="h-3 w-3 rounded-full bg-green-500/70"></div>
            <span class="ml-2 text-[10px] text-neutral-600 font-mono">rewind inspect latest</span>
          </div>
          <div class="bg-neutral-950 p-5 font-mono text-[11px] leading-loose">
            <div class="text-neutral-500">Session: <span class="text-neutral-300">support-agent</span>  Steps: <span class="text-neutral-300">8</span></div>
            <div class="mt-2 flex items-center gap-2"><span class="text-emerald-400">&#10003;</span> <span class="text-blue-400">&#x1f9e0;</span> <span class="text-neutral-300">gpt-4o</span> <span class="text-neutral-600 ml-auto">320ms 156&#x2193;</span></div>
            <div class="flex items-center gap-2"><span class="text-emerald-400">&#10003;</span> <span class="text-amber-400">&#x1f527;</span> <span class="text-neutral-300">web_search</span> <span class="text-neutral-600 ml-auto">45ms</span></div>
            <div class="flex items-center gap-2"><span class="text-emerald-400">&#10003;</span> <span class="text-blue-400">&#x1f9e0;</span> <span class="text-neutral-300">gpt-4o</span> <span class="text-neutral-600 ml-auto">650ms 280&#x2193;</span></div>
            <div class="flex items-center gap-2"><span class="text-red-400">&#x2717;</span> <span class="text-blue-400">&#x1f9e0;</span> <span class="text-neutral-300">gpt-4o</span> <span class="text-red-400/70 ml-auto">ERROR</span></div>
          </div>

          <div class="p-6">
            <div class="flex items-center gap-3 mb-3">
              <span class="flex h-8 w-8 items-center justify-center rounded-full bg-brand-primary/10 text-sm font-bold text-brand-primary">2</span>
              <h3 class="text-lg font-bold">Inspect</h3>
            </div>
            <p class="text-sm leading-relaxed text-neutral-400">
              See the exact context window at every step. Every message, system prompt, and tool response the model saw. TUI, Web Dashboard, or CLI.
            </p>
          </div>
        </div>
        <div class="hidden lg:block absolute -right-4 top-1/2 -translate-y-1/2 z-10 text-neutral-700" aria-hidden="true">
          <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </div>
      </div>

      <!-- Step 3: Fork & Fix -->
      <div class="group">
        <div class="overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-900/30 transition group-hover:border-neutral-700">
          <!-- Mockup diff view -->
          <div class="border-b border-neutral-800 bg-neutral-900 px-4 py-2.5 flex items-center gap-2">
            <div class="h-3 w-3 rounded-full bg-red-500/70"></div>
            <div class="h-3 w-3 rounded-full bg-yellow-500/70"></div>
            <div class="h-3 w-3 rounded-full bg-green-500/70"></div>
            <span class="ml-2 text-[10px] text-neutral-600 font-mono">rewind diff main fixed</span>
          </div>
          <div class="bg-neutral-950 p-5 font-mono text-[11px] leading-loose">
            <div class="text-neutral-500">Diverge at step <span class="text-neutral-300">4</span></div>
            <div class="mt-2"><span class="text-neutral-600">&#x2550;</span> <span class="text-neutral-500">Step 1-3</span> <span class="text-neutral-600">identical</span></div>
            <div><span class="text-brand-accent">&#x2260;</span> <span class="text-neutral-300">Step 4</span> <span class="text-red-400/70 line-through">stale data</span> <span class="text-neutral-600">&#x2192;</span> <span class="text-emerald-400/80">fresh data</span></div>
            <div><span class="text-brand-accent">&#x2260;</span> <span class="text-neutral-300">Step 5</span> <span class="text-red-400/70 line-through">error</span> <span class="text-neutral-600">&#x2192;</span> <span class="text-emerald-400/80">success</span></div>
          </div>

          <div class="p-6">
            <div class="flex items-center gap-3 mb-3">
              <span class="flex h-8 w-8 items-center justify-center rounded-full bg-brand-primary/10 text-sm font-bold text-brand-primary">3</span>
              <h3 class="text-lg font-bold">Fork & Fix</h3>
            </div>
            <p class="text-sm leading-relaxed text-neutral-400">
              Branch at the failure. Fix your code, replay from that point. Cached steps cost 0 tokens. Diff original vs. fixed. Score with LLM-as-judge.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
