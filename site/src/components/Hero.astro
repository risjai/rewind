---

---

<section class="relative overflow-hidden pt-32 pb-20 md:pt-44 md:pb-32">
  <!-- Gradient glow behind hero -->
  <div
    class="pointer-events-none absolute inset-0 -top-40 flex items-start justify-center"
  >
    <div
      class="h-[500px] w-[800px] rounded-full bg-brand-primary/8 blur-[120px]"
    >
    </div>
  </div>

  <div class="relative mx-auto max-w-4xl px-6 text-center">
    <div
      class="mb-6 inline-flex items-center gap-2 rounded-full border border-neutral-800 bg-neutral-900/50 px-4 py-1.5 text-sm text-neutral-400"
    >
      <span
        class="inline-block h-2 w-2 rounded-full bg-emerald-400 animate-pulse"
      ></span>
      Open source &middot; MIT licensed &middot; Single binary
    </div>

    <h1
      class="text-4xl font-extrabold tracking-tight sm:text-5xl md:text-6xl lg:text-7xl"
    >
      Agent broke at step 30?
      <br />
      <span
        class="bg-gradient-to-r from-brand-primary to-brand-accent bg-clip-text text-transparent"
      >
        Fix step 30.
      </span>
    </h1>

    <p class="mx-auto mt-6 max-w-2xl text-lg text-neutral-400 md:text-xl">
      Not steps 1 through 29 again. Fork at the failure, replay with
      the fix, <strong class="text-neutral-200">prove it works</strong>
      &ndash; all on your machine, never in someone else's cloud.
    </p>

    <!-- Install command -->
    <div class="mx-auto mt-10 max-w-md">
      <div
        class="group relative flex items-center rounded-xl border border-neutral-800 bg-neutral-900 px-5 py-3.5 font-mono text-sm"
      >
        <span class="text-neutral-500 select-none">$&nbsp;</span>
        <span class="text-brand-primary">pip install</span>
        <span class="ml-1.5 text-neutral-200">rewind-agent</span>
        <button
          id="copy-install"
          class="absolute right-3 rounded-md p-1.5 text-neutral-500 opacity-60 transition hover:opacity-100 hover:bg-neutral-800 hover:text-neutral-300"
          aria-label="Copy to clipboard"
          title="Copy to clipboard"
        >
          <svg
            id="copy-icon"
            class="h-4 w-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <rect x="9" y="9" width="13" height="13" rx="2" stroke-width="2"></rect>
            <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke-width="2"></path>
          </svg>
          <svg
            id="check-icon"
            class="h-4 w-4 text-emerald-400 hidden"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
        </button>
      </div>
      <p class="mt-3 text-xs text-neutral-500">
        Then run <code
          class="rounded bg-neutral-800 px-1.5 py-0.5 text-neutral-400"
          >rewind demo && rewind inspect latest</code
        > &ndash; no API keys needed.
      </p>
    </div>

    <!-- CTA buttons -->
    <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <a
        href="https://github.com/agentoptics/rewind#quickstart"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-xl bg-brand-primary px-6 py-3 text-sm font-semibold text-neutral-950 transition hover:bg-brand-primary/90"
      >
        Get started
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
        </svg>
      </a>
      <a
        href="#demo"
        class="inline-flex items-center gap-2 rounded-xl border border-neutral-700 px-6 py-3 text-sm font-semibold text-neutral-300 transition hover:border-neutral-600 hover:text-neutral-100"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M8 5v14l11-7z"></path>
        </svg>
        Watch demo
      </a>
    </div>
  </div>
</section>

<script>
  const COPY_RESET_MS = 2000;

  document.getElementById("copy-install")?.addEventListener("click", () => {
    navigator.clipboard.writeText("pip install rewind-agent");
    const copyIcon = document.getElementById("copy-icon");
    const checkIcon = document.getElementById("check-icon");
    copyIcon?.classList.add("hidden");
    checkIcon?.classList.remove("hidden");
    setTimeout(() => {
      copyIcon?.classList.remove("hidden");
      checkIcon?.classList.add("hidden");
    }, COPY_RESET_MS);
  });
</script>
