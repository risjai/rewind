---

---

<section class="relative overflow-hidden pt-32 pb-20 md:pt-44 md:pb-32">
  <!-- Gradient glow behind hero -->
  <div
    class="pointer-events-none absolute inset-0 -top-40 flex items-start justify-center"
  >
    <div
      class="h-[500px] w-[800px] rounded-full bg-brand-cyan/8 blur-[120px]"
    >
    </div>
  </div>

  <div class="relative mx-auto max-w-4xl px-6 text-center">
    <div
      class="mb-6 inline-flex items-center gap-2 rounded-full border border-neutral-800 bg-neutral-900/50 px-4 py-1.5 text-sm text-neutral-400"
    >
      <span
        class="inline-block h-2 w-2 rounded-full bg-emerald-400 animate-pulse"
      ></span>
      Open source &middot; MIT licensed &middot; single binary &middot; zero dependencies
    </div>

    <h1
      class="text-4xl font-extrabold tracking-tight sm:text-5xl md:text-6xl lg:text-7xl"
    >
      The time-travel debugger
      <br />
      <span
        class="bg-gradient-to-r from-brand-cyan to-brand-violet bg-clip-text text-transparent"
      >
        for AI agents
      </span>
    </h1>

    <p class="mx-auto mt-6 max-w-2xl text-lg text-neutral-400 md:text-xl">
      Other tools show what happened. Rewind lets you <strong
        class="text-neutral-200">fix it</strong
      > &mdash; without re-running.
    </p>

    <!-- Install command -->
    <div class="mx-auto mt-10 max-w-md">
      <div
        class="group relative flex items-center rounded-xl border border-neutral-800 bg-neutral-900 px-5 py-3.5 font-mono text-sm"
      >
        <span class="text-neutral-500 select-none">$&nbsp;</span>
        <span class="text-brand-cyan">pip install</span>
        <span class="ml-1.5 text-neutral-200">rewind-agent</span>
        <button
          id="copy-install"
          class="absolute right-3 rounded-md p-1.5 text-neutral-500 opacity-0 transition group-hover:opacity-100 hover:bg-neutral-800 hover:text-neutral-300"
          title="Copy to clipboard"
        >
          <svg
            id="copy-icon"
            class="h-4 w-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <rect x="9" y="9" width="13" height="13" rx="2" stroke-width="2"></rect>
            <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke-width="2"></path>
          </svg>
          <svg
            id="check-icon"
            class="h-4 w-4 text-emerald-400 hidden"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
        </button>
      </div>
      <p class="mt-3 text-xs text-neutral-500">
        Then run <code
          class="rounded bg-neutral-800 px-1.5 py-0.5 text-neutral-400"
          >rewind demo && rewind inspect latest</code
        > &mdash; no API keys needed.
      </p>
    </div>

    <!-- CTA buttons -->
    <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <a
        href="https://github.com/agentoptics/rewind"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-xl bg-brand-cyan px-6 py-3 text-sm font-semibold text-neutral-950 transition hover:bg-brand-cyan/90"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
          ></path>
        </svg>
        View on GitHub
      </a>
      <a
        href="#demo"
        class="inline-flex items-center gap-2 rounded-xl border border-neutral-700 px-6 py-3 text-sm font-semibold text-neutral-300 transition hover:border-neutral-600 hover:text-neutral-100"
      >
        Watch demo
        <svg
          class="h-4 w-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M19 9l-7 7-7-7"></path>
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  const COPY_RESET_MS = 2000;

  document.getElementById("copy-install")?.addEventListener("click", () => {
    navigator.clipboard.writeText("pip install rewind-agent");
    const copyIcon = document.getElementById("copy-icon");
    const checkIcon = document.getElementById("check-icon");
    copyIcon?.classList.add("hidden");
    checkIcon?.classList.remove("hidden");
    setTimeout(() => {
      copyIcon?.classList.remove("hidden");
      checkIcon?.classList.add("hidden");
    }, COPY_RESET_MS);
  });
</script>
